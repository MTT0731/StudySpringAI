              <option name="originalContent" value="&lt;!DOCTYPE html&gt;&#10;&lt;html lang=&quot;en&quot;&gt;&#10;&lt;head&gt;&#10;    &lt;meta charset=&quot;UTF-8&quot;&gt;&#10;    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1&quot;&gt;&#10;    &lt;title&gt;DeepSeek Chat Demo&lt;/title&gt;&#10;    &lt;style&gt;&#10;        :root{--bg:#0f1724;--card:#0b1220;--muted:#94a3b8;--accent:#60a5fa;--user:#7c3aed}&#10;        body{margin:0;font-family:Inter,ui-sans-serif,system-ui,Segoe UI,Roboto,&quot;Helvetica Neue&quot;,Arial;background:linear-gradient(180deg,#071028 0%, #081325 100%);color:#e6eef8;min-height:100vh;display:flex;align-items:center;justify-content:center}&#10;        .container{width:100%;max-width:760px;padding:24px}&#10;        .card{background:rgba(255,255,255,0.03);border-radius:12px;padding:18px;box-shadow:0 6px 18px rgba(2,6,23,0.6)}&#10;        header{display:flex;align-items:center;gap:12px;margin-bottom:12px}&#10;        h1{font-size:18px;margin:0}&#10;        .chat{height:420px;overflow:auto;padding:12px;border-radius:8px;background:linear-gradient(180deg,rgba(255,255,255,0.02),transparent);margin-bottom:12px}&#10;        .message{padding:10px 14px;border-radius:10px;margin-bottom:10px;max-width:82%}&#10;        .msg-user{background:linear-gradient(90deg,var(--user),#5b21b6);margin-left:auto;text-align:right}&#10;        .msg-bot{background:linear-gradient(90deg,#02203a,#08304a);text-align:left}&#10;        .meta{font-size:12px;color:var(--muted);margin-bottom:8px}&#10;        .controls{display:flex;gap:8px}&#10;        input[type=&quot;text&quot;]{flex:1;padding:10px 12px;border-radius:8px;border:1px solid rgba(255,255,255,0.06);background:transparent;color:inherit}&#10;        button{padding:10px 14px;border-radius:8px;border:none;background:var(--accent);color:#04233a;font-weight:600;cursor:pointer}&#10;        button:disabled{opacity:0.6;cursor:not-allowed}&#10;        .status{font-size:13px;color:var(--muted);margin-top:8px}&#10;        .error{color:#ff8a80}&#10;        @media (max-width:560px){.chat{height:60vh}}&#10;    &lt;/style&gt;&#10;&lt;/head&gt;&#10;&lt;body&gt;&#10;&lt;div class=&quot;container&quot;&gt;&#10;    &lt;div class=&quot;card&quot;&gt;&#10;        &lt;header&gt;&#10;            &lt;h1&gt;DeepSeek Chat 示例&lt;/h1&gt;&#10;            &lt;div style=&quot;flex:1&quot;&gt;&lt;/div&gt;&#10;            &lt;div class=&quot;meta&quot;&gt;通过后端调用 DeepSeek，后端返回纯文本响应&lt;/div&gt;&#10;        &lt;/header&gt;&#10;&#10;        &lt;div id=&quot;chat&quot; class=&quot;chat&quot; aria-live=&quot;polite&quot;&gt;&lt;/div&gt;&#10;&#10;        &lt;div class=&quot;controls&quot;&gt;&#10;            &lt;input id=&quot;messageInput&quot; type=&quot;text&quot; placeholder=&quot;输入消息，按 Enter 发送&quot; /&gt;&#10;            &lt;button id=&quot;sendBtn&quot;&gt;发送&lt;/button&gt;&#10;        &lt;/div&gt;&#10;        &lt;div id=&quot;status&quot; class=&quot;status&quot;&gt;&lt;/div&gt;&#10;    &lt;/div&gt;&#10;    &lt;p style=&quot;color:var(--muted);font-size:13px;margin-top:10px&quot;&gt;注意：此页面通过 GET 请求调用 &lt;code&gt;/api/chat/message?message=...&lt;/code&gt;&lt;/p&gt;&#10;&lt;/div&gt;&#10;&#10;&lt;script&gt;&#10;    const input = document.getElementById('messageInput');&#10;    const sendBtn = document.getElementById('sendBtn');&#10;    const chat = document.getElementById('chat');&#10;    const status = document.getElementById('status');&#10;&#10;    function appendMessage(text, kind='bot'){&#10;        const wrap = document.createElement('div');&#10;        wrap.className = 'message ' + (kind === 'user' ? 'msg-user' : 'msg-bot');&#10;        wrap.textContent = text;&#10;        chat.appendChild(wrap);&#10;        chat.scrollTop = chat.scrollHeight - chat.clientHeight + 100;&#10;    }&#10;&#10;    async function sendMessage(){&#10;        const msg = input.value.trim();&#10;        if(!msg) return;&#10;        appendMessage(msg, 'user');&#10;        input.value = '';&#10;        input.disabled = true;&#10;        sendBtn.disabled = true;&#10;        status.textContent = '发送中...';&#10;        status.classList.remove('error');&#10;        try{&#10;            const encoded = encodeURIComponent(msg);&#10;            const res = await fetch(`/api/chat/message?message=${encoded}`);&#10;            if(!res.ok){&#10;                const txt = await res.text();&#10;                throw new Error(`HTTP ${res.status} ${txt}`);&#10;            }&#10;            const bodyText = await res.text();&#10;            let display = bodyText;&#10;            try {&#10;                const data = JSON.parse(bodyText);&#10;                // Try common locations for assistant reply&#10;                if (data &amp;&amp; data.choices &amp;&amp; Array.isArray(data.choices) &amp;&amp; data.choices.length &gt; 0) {&#10;                    const first = data.choices[0];&#10;                    // common shapes: { message: { content: '...' } } or { text: '...' }&#10;                    if (first.message &amp;&amp; first.message.content) {&#10;                        display = first.message.content;&#10;                    } else if (first.text) {&#10;                        display = first.text;&#10;                    } else if (first.delta &amp;&amp; first.delta.content) {&#10;                        display = first.delta.content;&#10;                    } else {&#10;                        // fallback: stringify the JSON in pretty form&#10;                        display = JSON.stringify(data, null, 2);&#10;                    }&#10;                } else {&#10;                    display = JSON.stringify(data, null, 2);&#10;                }&#10;            } catch (e) {&#10;                // not JSON, keep bodyText&#10;                display = bodyText;&#10;            }&#10;            appendMessage(display, 'bot');&#10;            status.textContent = '已收到回复';&#10;        }catch(err){&#10;            status.textContent = '请求失败: ' + err.message;&#10;            status.classList.add('error');&#10;            appendMessage('错误: ' + err.message, 'bot');&#10;        }finally{&#10;            input.disabled = false;&#10;            sendBtn.disabled = false;&#10;            input.focus();&#10;        }&#10;    }&#10;&#10;    sendBtn.addEventListener('click', sendMessage);&#10;    input.addEventListener('keydown', (e)=&gt;{ if(e.key === 'Enter') sendMessage(); });&#10;&#10;    // Focus on load&#10;    input.focus();&#10;    // Small welcome message&#10;    appendMessage('欢迎使用 DeepSeek Chat 示例。输入问题并发送。', 'bot');&#10;&lt;/script&gt;&#10;&#10;&lt;/body&gt;&#10;&lt;/html&gt;" />
              <option name="updatedContent" value="&lt;!DOCTYPE html&gt;&#10;&lt;html lang=&quot;en&quot;&gt;&#10;&lt;head&gt;&#10;    &lt;meta charset=&quot;UTF-8&quot;&gt;&#10;    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1&quot;&gt;&#10;    &lt;title&gt;DeepSeek Chat Demo&lt;/title&gt;&#10;    &lt;style&gt;&#10;        :root{--bg:#0f1724;--card:#0b1220;--muted:#94a3b8;--accent:#60a5fa;--user:#7c3aed}&#10;        body{margin:0;font-family:Inter,ui-sans-serif,system-ui,Segoe UI,Roboto,&quot;Helvetica Neue&quot;,Arial;background:linear-gradient(180deg,#071028 0%, #081325 100%);color:#e6eef8;min-height:100vh;display:flex;align-items:center;justify-content:center}&#10;        .container{width:100%;max-width:760px;padding:24px}&#10;        .card{background:rgba(255,255,255,0.03);border-radius:12px;padding:18px;box-shadow:0 6px 18px rgba(2,6,23,0.6)}&#10;        header{display:flex;align-items:center;gap:12px;margin-bottom:12px}&#10;        h1{font-size:18px;margin:0}&#10;        .chat{height:420px;overflow:auto;padding:12px;border-radius:8px;background:linear-gradient(180deg,rgba(255,255,255,0.02),transparent);margin-bottom:12px}&#10;        .message{padding:10px 14px;border-radius:10px;margin-bottom:10px;max-width:82%}&#10;        .msg-user{background:linear-gradient(90deg,var(--user),#5b21b6);margin-left:auto;text-align:right}&#10;        .msg-bot{background:linear-gradient(90deg,#02203a,#08304a);text-align:left}&#10;        .meta{font-size:12px;color:var(--muted);margin-bottom:8px}&#10;        .controls{display:flex;gap:8px}&#10;        input[type=&quot;text&quot;]{flex:1;padding:10px 12px;border-radius:8px;border:1px solid rgba(255,255,255,0.06);background:transparent;color:inherit}&#10;        button{padding:10px 14px;border-radius:8px;border:none;background:var(--accent);color:#04233a;font-weight:600;cursor:pointer}&#10;        button:disabled{opacity:0.6;cursor:not-allowed}&#10;        .status{font-size:13px;color:var(--muted);margin-top:8px}&#10;        .error{color:#ff8a80}&#10;        @media (max-width:560px){.chat{height:60vh}}&#10;    &lt;/style&gt;&#10;&lt;/head&gt;&#10;&lt;body&gt;&#10;&lt;div class=&quot;container&quot;&gt;&#10;    &lt;div class=&quot;card&quot;&gt;&#10;        &lt;header&gt;&#10;            &lt;h1&gt;DeepSeek Chat 示例&lt;/h1&gt;&#10;            &lt;div style=&quot;flex:1&quot;&gt;&lt;/div&gt;&#10;            &lt;div class=&quot;meta&quot;&gt;通过后端调用 DeepSeek，后端返回纯文本响应&lt;/div&gt;&#10;        &lt;/header&gt;&#10;&#10;        &lt;div id=&quot;chat&quot; class=&quot;chat&quot; aria-live=&quot;polite&quot;&gt;&lt;/div&gt;&#10;&#10;        &lt;div class=&quot;controls&quot;&gt;&#10;            &lt;input id=&quot;messageInput&quot; type=&quot;text&quot; placeholder=&quot;输入消息，按 Enter 发送&quot; /&gt;&#10;            &lt;button id=&quot;sendBtn&quot;&gt;发送&lt;/button&gt;&#10;        &lt;/div&gt;&#10;        &lt;div id=&quot;status&quot; class=&quot;status&quot;&gt;&lt;/div&gt;&#10;    &lt;/div&gt;&#10;    &lt;p style=&quot;color:var(--muted);font-size:13px;margin-top:10px&quot;&gt;注意：此页面通过 GET 请求调用 &lt;code&gt;/api/chat/message?message=...&lt;/code&gt;&lt;/p&gt;&#10;&lt;/div&gt;&#10;&#10;&lt;script&gt;&#10;    const input = document.getElementById('messageInput');&#10;    const sendBtn = document.getElementById('sendBtn');&#10;    const chat = document.getElementById('chat');&#10;    const status = document.getElementById('status');&#10;&#10;    function appendMessage(text, kind='bot'){&#10;        const wrap = document.createElement('div');&#10;        wrap.className = 'message ' + (kind === 'user' ? 'msg-user' : 'msg-bot');&#10;        wrap.textContent = text;&#10;        chat.appendChild(wrap);&#10;        chat.scrollTop = chat.scrollHeight - chat.clientHeight + 100;&#10;    }&#10;&#10;    let currentEventSource = null;&#10;&#10;    function startStream(msg) {&#10;        // Close existing stream if any&#10;        if (currentEventSource) {&#10;            try { currentEventSource.close(); } catch (e) {}&#10;            currentEventSource = null;&#10;        }&#10;&#10;        const encoded = encodeURIComponent(msg);&#10;        const es = new EventSource(`/api/chat/stream?message=${encoded}`);&#10;        currentEventSource = es;&#10;&#10;        // Create a bot message placeholder&#10;        const botWrap = document.createElement('div');&#10;        botWrap.className = 'message msg-bot';&#10;        botWrap.textContent = '';&#10;        chat.appendChild(botWrap);&#10;        chat.scrollTop = chat.scrollHeight - chat.clientHeight + 100;&#10;&#10;        status.textContent = '正在接收流式回复...';&#10;        status.classList.remove('error');&#10;&#10;        es.onmessage = function(e) {&#10;            // default message events — append data&#10;            if (!e.data) return;&#10;            botWrap.textContent += e.data;&#10;            chat.scrollTop = chat.scrollHeight - chat.clientHeight + 100;&#10;        };&#10;&#10;        es.addEventListener('done', function() {&#10;            status.textContent = '回复完成';&#10;            try { es.close(); } catch (e) {}&#10;            currentEventSource = null;&#10;            input.disabled = false;&#10;            sendBtn.disabled = false;&#10;            input.focus();&#10;        });&#10;&#10;        es.onerror = function(err) {&#10;            status.textContent = '流式连接出错';&#10;            status.classList.add('error');&#10;            try { es.close(); } catch (e) {}&#10;            currentEventSource = null;&#10;            input.disabled = false;&#10;            sendBtn.disabled = false;&#10;        };&#10;    }&#10;&#10;    function sendMessage(){&#10;        const msg = input.value.trim();&#10;        if(!msg) return;&#10;        appendMessage(msg, 'user');&#10;        input.value = '';&#10;        input.disabled = true;&#10;        sendBtn.disabled = true;&#10;        // start SSE stream&#10;        startStream(msg);&#10;    }&#10;&#10;    sendBtn.addEventListener('click', sendMessage);&#10;    input.addEventListener('keydown', (e)=&gt;{ if(e.key === 'Enter') sendMessage(); });&#10;&#10;    // Focus on load&#10;    input.focus();&#10;    // Small welcome message&#10;    appendMessage('欢迎使用 DeepSeek Chat 示例。输入问题并发送。', 'bot');&#10;&lt;/script&gt;&#10;&#10;&lt;/body&gt;&#10;&lt;/html&gt;" />
