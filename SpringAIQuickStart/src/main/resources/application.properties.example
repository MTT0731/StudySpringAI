# Example (sanitized) application.properties
# This file is safe to commit to source control. Replace the placeholder values
# in a local `application.properties` file (not checked into git) with your
# real credentials.

# DeepSeek endpoint base URL (include scheme, e.g. https://api.deepseek.example)
spring.ai.deepseek.base-url=https://api.deepseek.example

# DeepSeek API key - DO NOT commit your real key. Replace in a local application.properties
spring.ai.deepseek.api-key=REPLACE_WITH_YOUR_DEEPSEEK_API_KEY

# Model to use for chat (keep default unless you have another model)
spring.ai.deepseek.chat.options.model=deepseek-chat

# Server port (optional)
server.port=8080

# Logging (optional)
logging.level.root=INFO
